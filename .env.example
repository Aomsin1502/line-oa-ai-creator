# Line Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here

# Your public server URL (must be HTTPS for Line webhook)
# Example: https://your-app.railway.app  or use ngrok for local dev
BASE_URL=https://your-server-url.com

# Port (default 3000)
PORT=3000

# PromptPay ID (phone number or national ID)
# Example: 0812345678  or  1234567890123
PROMPTPAY_ID=0812345678

# Your own Line User ID (for admin commands like /activate)
# Get it by messaging your bot and checking the webhook logs
ADMIN_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
